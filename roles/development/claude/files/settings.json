{
  "cleanupPeriodDays": 30,
  "env": {
    "ENABLE_LSP_TOOL": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(git add*)",
      "Bash(git status*)",
      "Bash(git commit*)",
      "Bash(chmod +x:*)"
    ],
    "deny": [
      "~/.ssh/id_*",
      "~/.aws/credentials"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "clj-paren-repair-claude-hook --cljfmt"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "clj-paren-repair-claude-hook --cljfmt"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "clj-paren-repair-claude-hook --cljfmt"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "playwright@claude-plugins-official": false,
    "clojure-lsp@clojure-lsp-marketplace": false,
    "skill-creator@claude-plugins-official": true,
    "newsletter-writer@brightmotive-claude-plugins": true,
    "autoresearch@autoresearch": true,
    "isms@brightmotive-claude-plugins": true,
    "mailerlite@brightmotive-claude-plugins": true,
    "screenshots@brightmotive-claude-plugins": true
  },
  "extraKnownMarketplaces": {
    "clojure-lsp-marketplace": {
      "source": {
        "source": "github",
        "repo": "Bigsy/claude-clojure-lsp"
      }
    },
    "brightmotive-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "brightin/claude-plugins"
      },
      "autoUpdate": true
    },
    "autoresearch": {
      "source": {
        "source": "github",
        "repo": "uditgoenka/autoresearch"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "showClearContextOnPlanAccept": true,
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "autoCompactEnabled": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
